    {
     "id": "python-101",
     "type": "block",
     "position": {
      "x": 212.77015160664638,
      "y": -95.19994826411167
     },
     "data": {
      "type": "python",
      "label": "Python Block",
      "description": "Phân loại chức năng",
      "code": "import re\n\n# 1. Bóc lấy nội dung chữ\ntext_content = input_data.get(\"text\", \"\")\n\n# 2. Định nghĩa hàm xử lý\ndef phan_loai_du_lieu(text):\n    pattern = r\"^\\s*([A-Za-z0-9]+)\\s*:\\s*([A-Za-z0-9]+)\\s*-\\s*([A-Za-z0-9]+)\\s*$\"\n    match = re.match(pattern, str(text).strip())\n    \n    if match:\n        pha_loai, ma_np, ma_kh = match.groups()\n        return {\n            \"PhaLoai\": pha_loai,\n            \"MaNPP\": ma_np,\n            \"MaKH\": ma_kh,\n            \"status\": \"ok\"\n        }\n    else:\n        return {\n            \"PhaLoai\": None,\n            \"MaNPP\": None,\n            \"MaKH\": None,\n            \"status\": \"error\"\n        }\n\n# 3. Lấy kết quả phân loại\noutput_data = phan_loai_du_lieu(text_content)\n\n# 4. === PHẦN THÊM VÀO ĐỂ GIỮ LẠI CHAT_ID ===\n# Lấy lại toàn bộ thông tin gốc ban đầu (có chứa chat_id, from_name...)\nmerged_data = input_data.copy()\n# Cập nhật kết quả phân loại vào chung\nmerged_data.update(output_data)\n# Gán trả lại thành đầu ra chính thức\noutput_data = merged_data\n\n# In kết quả ra log\nprint(\"Dữ liệu phân loại:\", output_data)\n",
      "inPosition": "left",
      "outPosition": "right"
     }
    },
